<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Atlas of Elasmobranchs</title>
    <link rel="stylesheet" type="text/css" href="/assets/style.css"/>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600&family=Raleway:ital,wght@0,300;0,400;1,300&display=swap" rel="stylesheet">
</head>
<body>

    <!-- Full-screen Three.js canvas — the entire page IS the scene -->
    <canvas id="modelCanvas"></canvas>

    <!-- Retractable nav — fades out on idle, snaps back on any mouse/touch activity -->
    <nav class="site-nav" id="siteNav">
        <div class="nav-inner">
            <span class="nav-title">Atlas of Elasmobranchs</span>
            <span class="nav-divider">·</span>
            <span class="nav-sub">Interactive 3D Specimen Viewer</span>
        </div>
    </nav>

    <!-- Ambient corner hints — always subtle, always visible -->
    <div class="corner-hints">
        <span>⟳ drag to orbit</span>
        <span>⊕ scroll to zoom</span>
    </div>

    <!-- Specimen overlay — populated by JS when a model is active -->
    <div class="specimen-overlay" id="specimenOverlay">
        <p class="specimen-name" id="specimenName"></p>
        <p class="specimen-class" id="specimenClass"></p>
    </div>

    <script src="/assets/viewerBundle.js"></script>
    <script src="/assets/navBundle.js"></script>
</body>
</html>
